# ===========================================
# AgentTeam — Environment Variables
# Copy this file to .env and fill in values
# ===========================================

# --- Database ---
POSTGRES_USER=agentteam
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agentteam
DATABASE_URL=postgresql://agentteam:changeme@postgres:5432/agentteam

# --- Redis ---
REDIS_URL=redis://redis:6379

# --- MinIO (S3-compatible file storage) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=agentteam-files

# --- Auth ---
JWT_SECRET=generate-64-chars-random-string-here
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Encryption (for integration credentials in DB) ---
CREDENTIALS_ENCRYPTION_KEY=generate-32-bytes-hex-string-here

# --- OpenRouter (single AI provider for text, images, video) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Playwright Service ---
PLAYWRIGHT_SERVICE_URL=http://playwright-service:3100
NOVNC_PASSWORD=changeme

# --- Push Notifications ---
FCM_SERVER_KEY=

# --- External Integrations (configure via admin panel) ---
# These are stored encrypted in DB, not here.
# WHATSAPP_API_KEY=
# INSTAGRAM_ACCESS_TOKEN=
# NOTION_TOKEN=
